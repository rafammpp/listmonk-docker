# Timezone (set to your legal/operational timezone)
TZ=Europe/Madrid

# Domain used by Nginx and Listmonk links
LISTMONK_DOMAIN=news.example.com

# Database configuration
DB_USER=listmonk
DB_PASSWORD=change_this_with_a_long_random_password
DB_NAME=listmonk

# Optional: one-time Super Admin bootstrap (recommended to leave empty in .env)
# Use only on first startup, then remove.
LISTMONK_ADMIN_USER=
LISTMONK_ADMIN_PASSWORD=