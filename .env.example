# Timezone (set to your legal/operational timezone)
TZ=UTC

# Domain used by Nginx and Listmonk links
LISTMONK_DOMAIN=news.example.com

# Backup configuration
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE=0 3 * * *

# Cloudflare R2 configuration
R2_BUCKET=listmonk-backups
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PREFIX=listmonk